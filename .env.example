DATABASE_URL=postgresql://user:password@localhost:5432/buykori_adsync
REDIS_URL=redis://localhost:6379/0
ADMIN_USERNAME=admin
# Generate with: python scripts/keys/hash_admin_password.py
ADMIN_PASSWORD=pbkdf2_sha256$210000$change-me-salt$change-me-hash
ADMIN_API_KEY=change-me-random-url-safe-token
ENCRYPTION_KEY=change-me-valid-fernet-key

# Optional production hardening
PRIMARY_DOMAIN=api.buykori.app
ALLOWED_HOSTS=localhost,127.0.0.1,testserver,buykori.app,www.buykori.app,client.buykori.app,admin.buykori.app,api.buykori.app,track.buykori.app
ENABLE_DOCS=false
SKIP_CREATE_ALL=true
ENABLE_CREATE_ALL=false
ENABLE_OUTBOX_IN_WEB=false
ENABLE_RETRY_IN_WEB=false
ENABLE_MAINTENANCE_IN_WEB=false
ALLOW_LEGACY_PLAINTEXT_TOKENS=false
ALLOW_LEGACY_ADMIN_PASSWORD=false
TRACKING_BODY_LIMIT_BYTES=262144
WEBHOOK_BODY_LIMIT_BYTES=2097152
ADMIN_SESSION_COOKIE=buykori_admin_session
ADMIN_SESSION_SECONDS=86400
ADMIN_CSRF_COOKIE=buykori_admin_csrf
ADMIN_CSRF_HEADER=X-Admin-CSRF-Token
ADMIN_COOKIE_DOMAIN=.buykori.app
ADMIN_COOKIE_SECURE=true
ADMIN_COOKIE_SAMESITE=none
SECURITY_HEADERS_ENABLED=true
SECURITY_HSTS_ENABLED=true
CSP_CONNECT_SRC_EXTRA=
CONTENT_SECURITY_POLICY=
CSP_STRICT_NONCE=false
REFERRER_POLICY=strict-origin-when-cross-origin
PERMISSIONS_POLICY=camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=()
STRICT_TRANSPORT_SECURITY=max-age=31536000; includeSubDomains
CLIENT_SESSION_DAYS=30
CLIENT_COOKIE_DOMAIN=.buykori.app
CLIENT_COOKIE_SECURE=true
CLIENT_COOKIE_SAMESITE=none
CLIENT_AUTH_ALLOWED_HOSTS=buykori.app,www.buykori.app,client.buykori.app,localhost,127.0.0.1
CAPI_SIGNATURE_WINDOW_SECONDS=300
REQUIRE_TRACKER_INGEST_TOKEN=false
TRACKER_INGEST_TOKEN_TTL_SECONDS=900
REQUIRE_WC_WEBHOOK_SIGNATURE=true
ALLOW_WC_WEBHOOK_API_KEY_SECRET_FALLBACK=false
ALLOW_SHOPIFY_PLAINTEXT_SHARED_SECRET=false
REQUIRE_COURIER_WEBHOOK_SECRET=true
# New courier/webhook integrations should send secrets in X-API-Key,
# X-Courier-Webhook-Secret, provider-specific secret headers, or
# Authorization: Bearer. Query-string tokens remain legacy fallback only.
COURIER_WEBHOOK_SECRET=change-me-random-courier-webhook-secret
STEADFAST_BEARER_TOKEN=change-me-random-steadfast-webhook-bearer-token
PATHAO_MERCHANT_WEBHOOK_INTEGRATION_SECRET=change-me-pathao-integration-response-token
REQUIRE_SIGNED_DOMAIN_PROOF=true
PLUGIN_PROTECTED_PACKAGE=true
PLUGIN_PRECONFIGURED_DOWNLOADS=false
PUBLIC_GATEWAY_BASE_URL=https://api.buykori.app
ALLOWED_GATEWAY_HOSTS=api.buykori.app,track.buykori.app
GEOIP_ENRICH_IN_REQUEST=false
TRACKER_ENRICH_IN_REQUEST=false
GEOIP_DB_PATH=GeoLite2-City.mmdb
GEOIP_MAX_AGE_DAYS=7
MAXMIND_EDITION_ID=GeoLite2-City
MAXMIND_ACCOUNT_ID=
MAXMIND_LICENSE_KEY=
ALLOW_GEOIP_FALLBACK_MIRROR=false
TRUST_PROXY_HEADERS=false
HTTP_MAX_CONNECTIONS=20
HTTP_MAX_KEEPALIVE_CONNECTIONS=10
HTTP_TIMEOUT_SECONDS=15.0
EVENT_WORKER_BATCH_SIZE=5
EVENT_WORKER_POLL_SECONDS=3.0
EVENT_OUTBOX_MAX_ATTEMPTS=8
COURIER_POLL_LOCK_TTL_SECONDS=1200
COURIER_POLL_MAX_CONCURRENCY=8
COURIER_BOOKING_WORKER_BATCH_SIZE=10
COURIER_BOOKING_WORKER_POLL_SECONDS=1.0
COURIER_BOOKING_STALE_LOCK_SECONDS=600
COURIER_BOOKING_MAX_ATTEMPTS=8
COURIER_BOOKING_QUEUE_WARN_SECONDS=60
COURIER_BOOKING_PROCESSING_WARN_SECONDS=600
EVENT_LOG_RETENTION_DAYS=60
ACTIONABLE_EVENT_RETENTION_DAYS=90
INCOMPLETE_CHECKOUT_RETENTION_DAYS=180
DB_POOL_SIZE=8
DB_MAX_OVERFLOW=4
DB_POOL_TIMEOUT=10
DB_POOL_RECYCLE=300
PLUGIN_VERSION=1.2.49
